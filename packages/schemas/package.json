{
  "name": "@repo/schemas",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "exports": {
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./dist/auth.js"
    },
    "./newsletter": {
      "types": "./src/newsletter.ts",
      "default": "./dist/newsletter.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch -p tsconfig.build.json --preserveWatchOutput",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
